# Copy to .env (here or in the repo root) and fill in your values.
# The demo reads these at startup. Existing shell env vars take precedence.

GAMEPULSE_API_URL=http://localhost:8000
GAMEPULSE_API_KEY=gpk_your_key_here
GAMEPULSE_PROJECT_SLUG=your-project-slug

# Optional — where the "Open Dashboard" button points (default below)
GAMEPULSE_DASHBOARD_URL=http://localhost:8501
